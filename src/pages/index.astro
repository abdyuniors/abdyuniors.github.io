---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { Image } from 'astro:assets';
import fotoProfil from '../assets/foto-abdy.png';
---

<Layout title="Abdyunior Januar Suek - Portfolio">
    <!-- Mengurangi padding top dan bottom main wrapper -->
    <main class="overflow-hidden">
        
        <!-- Hero Section -->
        <!-- Mengurangi min-height dan padding y -->
        <section class="min-h-[75vh] flex items-center py-12 md:py-16 px-4 max-w-6xl mx-auto">
            <div class="grid md:grid-cols-5 gap-8 md:gap-12 items-center w-full">
                
                <!-- Bagian Kiri (Teks & Tombol) -->
                <div class="md:col-span-3 text-center md:text-left" data-aos="fade-right">
                    <p class="text-indigo-400 font-mono mb-2 font-medium tracking-wide text-sm md:text-base">&gt; Halo, saya</p>
                    
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-white mb-3">
                        <span class="bg-gradient-to-r from-indigo-400 to-teal-400 bg-clip-text text-transparent">Abdy</span>unior
                    </h1>
                    
                    <!-- Typing Effect - Sedikit penyesuaian margin -->
                    <div class="text-lg md:text-xl lg:text-2xl text-slate-400 font-medium h-8 mb-5 flex justify-center md:justify-start items-center">
                        Saya seorang&nbsp;<span id="typing-text" class="text-indigo-400 border-r-2 border-indigo-400 pr-1 leading-none"></span>
                    </div>
                    
                    <!-- Deskripsi Baru - Menggunakan em untuk margin-bottom agar proposional -->
                    <p class="text-slate-400 text-base md:text-lg leading-relaxed mb-[1.5em] max-w-lg mx-auto md:mx-0">
                        Membangun aplikasi Android dan sistem web modern, responsif, dan user friendly dengan fokus pada performa, pengalaman pengguna, dan solusi yang efektif.
                    </p>
                    
                    <div class="flex flex-wrap justify-center md:justify-start gap-3 md:gap-4">
                        <a href="#projects" class="px-5 py-2.5 md:px-6 md:py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-xl shadow-lg shadow-indigo-500/20 transition-all duration-300 hover:-translate-y-1 text-sm md:text-base">
                            Lihat Proyek
                        </a>
                        <a href="/cv.pdf" target="_blank" class="px-5 py-2.5 md:px-6 md:py-3 bg-slate-900 hover:bg-slate-800 text-white font-medium rounded-xl border border-slate-700 transition-all duration-300 hover:-translate-y-1 text-sm md:text-base">
                            Download CV
                        </a>
                    </div>
                </div>

                <!-- Bagian Kanan (Foto Profil) -->
                <!-- mt-8 untuk mobile agar tidak terlalu jauh -->
                <div class="md:col-span-2 mt-8 md:mt-0" data-aos="fade-left" data-aos-delay="200">
                    <div class="relative max-w-xs md:max-w-sm mx-auto md:ml-auto md:mr-0 group">
                        <div class="relative max-w-xs md:max-w-sm mx-auto md:ml-auto md:mr-0 group" data-tilt data-tilt-max="10" data-tilt-speed="400" data-tilt-glare="true" data-tilt-max-glare="0.2">
                            <div class="absolute inset-0 bg-gradient-to-tr from-indigo-500 to-teal-500 rounded-[2rem] blur-2xl opacity-15 group-hover:opacity-30 transition-opacity duration-500"></div>
                            <div class="relative bg-slate-900/50 border border-slate-800/80 rounded-[2rem] overflow-hidden aspect-[4/5] shadow-2xl">
                                <Image 
                                src={fotoProfil} 
                                alt="Foto Profil Abdy" 
                                class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
                                loading="eager"
                                fetchpriority="high"
                            />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Tech Stack Section -->
        <!-- py-12 md:py-16 (jarak antar section medium) -->
        <section id="tech" class="py-8 md:py-12 px-4 max-w-6xl mx-auto">
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-6 md:mb-8 flex items-center gap-3" data-aos="fade-right">
                <span class="text-indigo-500 font-mono text-xl md:text-2xl">01.</span> Tech Stack & Alat
            </h2>
            
            <!-- Menggunakan gap-3 untuk mobile agar lebih rapat -->
            <div class="grid grid-cols-2 md:grid-cols-6 gap-3 md:gap-4" data-aos="fade-up">
                
                <!-- Card Item - padding dikurangi (p-3 md:p-4) -->
                <div class="spotlight-card p-3 md:p-4 h-28 md:h-32 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-red-500/50 hover:bg-slate-900 hover:-translate-y-1 group" data-aos="zoom-in" data-aos-delay="100" data-tilt data-tilt-max="15" data-tilt-scale="1.05">
                    <i class="fa-brands fa-laravel text-3xl md:text-4xl text-slate-500 group-hover:text-red-500 transition-colors mb-2"></i>
                    <span class="text-xs font-medium text-slate-400 group-hover:text-white transition-colors text-center">Laravel / PHP</span>
                </div>

                <div class="spotlight-card p-3 md:p-4 h-28 md:h-32 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-purple-500/50 hover:bg-slate-900 hover:-translate-y-1 group" data-aos="zoom-in" data-aos-delay="200" data-tilt data-tilt-max="15" data-tilt-scale="1.05">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-8 h-8 md:w-10 md:h-10 text-slate-500 group-hover:text-purple-500 transition-colors mb-2" fill="currentColor">
                        <path d="M24 24H0V0h24L12 12Z"/>
                    </svg>
                    <span class="text-xs font-medium text-slate-400 group-hover:text-white transition-colors text-center">Kotlin / Android</span>
                </div>

                <div class="spotlight-card p-3 md:p-4 h-28 md:h-32 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-orange-500/50 hover:bg-slate-900 hover:-translate-y-1 group" data-aos="zoom-in" data-aos-delay="300" data-tilt data-tilt-max="15" data-tilt-scale="1.05">
                    <!-- Astro Logo disesuaikan ukurannya -->
                    <svg class="w-8 h-8 md:w-10 md:h-10 text-slate-500 group-hover:text-orange-500 transition-colors mb-2" viewBox="0 0 85 107" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M27.5893 91.1365C22.7555 86.7178 21.3443 77.4335 23.3583 70.7072C26.8503 74.948 31.6888 76.2914 36.7005 77.0497C44.4374 78.2199 52.0358 77.7822 59.2231 74.2459C60.0453 73.841 60.8052 73.3027 61.7036 72.7574C62.378 74.714 62.5535 76.6892 62.3179 78.6996C61.7452 83.5957 59.3086 87.3778 55.4332 90.2448C53.8835 91.3916 52.2437 92.4167 50.6432 93.4979C45.7262 96.8213 44.3959 100.718 46.2435 106.386C46.2874 106.525 46.3267 106.663 46.426 107C43.9155 105.876 42.0817 104.24 40.6844 102.089C39.2086 99.8193 38.5065 97.3081 38.4696 94.5909C38.4511 93.2686 38.4511 91.9345 38.2733 90.6309C37.8391 87.4527 36.3471 86.0297 33.5364 85.9478C30.6518 85.8636 28.37 87.6469 27.7649 90.4554C27.7187 90.6707 27.6517 90.8837 27.5847 91.1341L27.5893 91.1365Z" fill="currentColor"/>
                        <path d="M0 69.5866C0 69.5866 14.3139 62.6137 28.6678 62.6137L39.4901 29.1204C39.8953 27.5007 41.0783 26.3999 42.4139 26.3999C43.7495 26.3999 44.9325 27.5007 45.3377 29.1204L56.1601 62.6137C73.1601 62.6137 84.8278 69.5866 84.8278 69.5866C84.8278 69.5866 60.5145 3.35233 60.467 3.21944C59.7692 1.2612 58.5911 0 57.0029 0H27.8274C26.2392 0 25.1087 1.2612 24.3634 3.21944C24.3108 3.34983 0 69.5866 0 69.5866Z" fill="currentColor"/>
                    </svg>
                    <span class="text-xs font-medium text-slate-400 group-hover:text-white transition-colors text-center">Astro</span>
                </div>

                <div class="spotlight-card p-3 md:p-4 h-28 md:h-32 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-teal-500/50 hover:bg-slate-900 hover:-translate-y-1 group" data-aos="zoom-in" data-aos-delay="400" data-tilt data-tilt-max="15" data-tilt-scale="1.05">
                    <svg class="w-8 h-8 md:w-10 md:h-10 text-slate-500 group-hover:text-teal-400 transition-colors mb-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12.001,4.8c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624 C13.666,10.618,15.027,12,18.001,12c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624 C16.337,6.182,14.976,4.8,12.001,4.8z M6.001,12c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6,2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624 c1.177,1.194,2.538,2.576,5.512,2.576c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624 C10.337,13.382,8.976,12,6.001,12z"/></svg>
                    <span class="text-xs font-medium text-slate-400 group-hover:text-white transition-colors text-center">Tailwind CSS</span>
                </div>

                <div class="spotlight-card p-3 md:p-4 h-28 md:h-32 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-pink-500/50 hover:bg-slate-900 hover:-translate-y-1 group" data-aos="zoom-in" data-aos-delay="500" data-tilt data-tilt-max="15" data-tilt-scale="1.05">
                    <i class="fa-brands fa-figma text-3xl md:text-4xl text-slate-500 group-hover:text-pink-500 transition-colors mb-2"></i>
                    <span class="text-xs font-medium text-slate-400 group-hover:text-white transition-colors text-center">Figma</span>
                </div>

                <div class="spotlight-card p-3 md:p-4 h-28 md:h-32 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-blue-500/50 hover:bg-slate-900 hover:-translate-y-1 group" data-aos="zoom-in" data-aos-delay="600" data-tilt data-tilt-max="15" data-tilt-scale="1.05">
                    <div class="w-8 h-8 md:w-10 md:h-10 flex items-center justify-center mb-2">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 25.6 25.6" class="w-full h-full object-contain text-slate-500 group-hover:text-blue-400 transition-colors" fill="none">
                            <path d="M179.076 94.886c-3.568-.1-6.336.268-8.656 1.25-.668.27-1.74.27-1.828 1.116.357.355.4.936.713 1.428.535.893 1.473 2.096 2.32 2.72l2.855 2.053c1.74 1.07 3.703 1.695 5.398 2.766.982.625 1.963 1.428 2.945 2.098.5.357.803.938 1.428 1.16v-.135c-.312-.4-.402-.98-.713-1.428l-1.34-1.293c-1.293-1.74-2.9-3.258-4.64-4.506-1.428-.982-4.55-2.32-5.13-3.97l-.088-.1c.98-.1 2.14-.447 3.078-.715 1.518-.4 2.9-.312 4.46-.713l2.143-.625v-.4c-.803-.803-1.383-1.874-2.23-2.632-2.275-1.963-4.775-3.882-7.363-5.488-1.383-.892-3.168-1.473-4.64-2.23-.537-.268-1.428-.402-1.74-.848-.805-.98-1.25-2.275-1.83-3.436l-3.658-7.763c-.803-1.74-1.295-3.48-2.275-5.086-4.596-7.585-9.594-12.18-17.268-16.687-1.65-.937-3.613-1.34-5.7-1.83l-3.346-.18c-.715-.312-1.428-1.16-2.053-1.562-2.543-1.606-9.102-5.086-10.977-.5-1.205 2.9 1.785 5.755 2.8 7.228.76 1.026 1.74 2.186 2.277 3.346.3.758.4 1.562.713 2.365.713 1.963 1.383 4.15 2.32 5.98.5.937 1.025 1.92 1.65 2.767.357.5.982.714 1.115 1.517-.625.893-.668 2.23-1.025 3.347-1.607 5.042-.982 11.288 1.293 15 .715 1.115 2.4 3.57 4.686 2.632 2.008-.803 1.56-3.346 2.14-5.577.135-.535.045-.892.312-1.25v.1l1.83 3.703c1.383 2.186 3.793 4.462 5.8 5.98 1.07.803 1.918 2.187 3.256 2.677v-.135h-.088c-.268-.4-.67-.58-1.027-.892-.803-.803-1.695-1.785-2.32-2.677-1.873-2.498-3.523-5.265-4.996-8.12-.715-1.383-1.34-2.9-1.918-4.283-.27-.536-.27-1.34-.715-1.606-.67.98-1.65 1.83-2.143 3.034-.848 1.918-.936 4.283-1.248 6.737-.18.045-.1 0-.18.1-1.426-.356-1.918-1.83-2.453-3.078-1.338-3.168-1.562-8.254-.402-11.913.312-.937 1.652-3.882 1.117-4.774-.27-.848-1.16-1.338-1.652-2.008-.58-.848-1.203-1.918-1.605-2.855-1.07-2.5-1.605-5.265-2.766-7.764-.537-1.16-1.473-2.365-2.232-3.435-.848-1.205-1.783-2.053-2.453-3.48-.223-.5-.535-1.294-.178-1.83.088-.357.268-.5.623-.58.58-.5 2.232.134 2.812.4 1.65.67 3.033 1.294 4.416 2.23.625.446 1.295 1.294 2.098 1.518h.938c1.428.312 3.033.1 4.37.5 2.365.76 4.506 1.874 6.426 3.08 5.844 3.703 10.664 8.968 13.92 15.26.535 1.026.758 1.963 1.25 3.034.938 2.187 2.098 4.417 3.033 6.56.938 2.097 1.83 4.24 3.168 5.98.67.937 3.346 1.427 4.55 1.918.893.4 2.275.76 3.08 1.25 1.516.937 3.033 2.008 4.46 3.034.713.534 2.945 1.65 3.078 2.54zm-45.5-38.772a7.09 7.09 0 0 0-1.828.223v.1h.088c.357.714.982 1.205 1.428 1.83l1.027 2.142.088-.1c.625-.446.938-1.16.938-2.23-.268-.312-.312-.625-.535-.937-.268-.446-.848-.67-1.206-1.026z" transform="matrix(.390229 0 0 .38781 -46.300037 -16.856717)" fill-rule="evenodd" fill="currentColor"></path>
                        </svg>
                    </div>
                    <span class="text-xs font-medium text-slate-400 group-hover:text-white transition-colors text-center">MySQL</span>
                </div>
            </div>
        </section>

        <!-- Projects Section -->
        <section id="projects" class="py-8 md:py-12 px-4 max-w-6xl mx-auto" data-aos="fade-up">
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-6 md:mb-8 flex items-center gap-3">
                <span class="text-indigo-500 font-mono text-xl md:text-2xl">02.</span> Proyek Unggulan
            </h2>
            
            <div class="grid md:grid-cols-2 gap-6">
                <div data-aos="zoom-in" data-aos-delay="100">
                    <div data-tilt data-tilt-max="5" data-tilt-speed="400" data-tilt-glare="true" data-tilt-max-glare="0.1" class="h-full rounded-2xl">
                        <ProjectCard 
                            title="Sistem Pendukung Keputusan (SPK) KNN"
                            type="Web Application"
                            typeColor="text-red-400 bg-red-500/10 border-red-500/10"
                            link="https://github.com/abdyuniors/spkknn"
                            description="Otomatisasi penentuan status kelayakan jalan kendaraan angkutan umum menggunakan algoritma klasifikasi K-Nearest Neighbor (KNN) untuk akurasi data keputusan."
                            techStacks={['Laravel', 'MySQL', 'Tailwind CSS']}
                        />
                    </div>
                </div>
                
                <div data-aos="zoom-in" data-aos-delay="200">
                    <div data-tilt data-tilt-max="5" data-tilt-speed="400" data-tilt-glare="true" data-tilt-max-glare="0.1" class="h-full rounded-2xl">
                        <ProjectCard 
                            title="Lapor TVRI NTT"
                            type="Mobile Application"
                            typeColor="text-emerald-400 bg-emerald-500/10 border-emerald-500/10"
                            link="https://github.com/abdyuniors/LaporTVRINTT"
                            description="Aplikasi pelaporan internal dan publik untuk stasiun penyiaran TVRI NTT yang dirancang native dengan berfokus pada siklus proses yang responsif dan real-time."
                            techStacks={['Kotlin', 'Firebase', 'Material Design']}
                        />
                    </div>
                </div>

                <div data-aos="zoom-in" data-aos-delay="300" class="md:col-span-2 md:max-w-2xl md:mx-auto w-full">
                    <div data-tilt data-tilt-max="5" data-tilt-speed="400" data-tilt-glare="true" data-tilt-max-glare="0.1" class="h-full rounded-2xl">
                        <ProjectCard 
                            title="QuiisinApp"
                            type="Mobile Application"
                            typeColor="text-amber-400 bg-amber-500/10 border-amber-500/10"
                            link="https://github.com/abdyuniors/QuiisinApp"
                            description="Aplikasi pasar (marketplace) kuesioner interaktif yang mempertemukan peneliti dengan responden spesifik secara efisien. Pengguna dapat mengisi kuesioner yang tersedia untuk mengumpulkan poin reward, atau bertindak sebagai peneliti untuk mencari responden yang tepat bagi studi mereka."
                            techStacks={['Kotlin', 'LiveData', 'Retrofit', 'Local Storage']}
                        />
                    </div>
                </div>
            </div>
        </section>

        <!-- Contact Section -->
        <!-- py-16 md:py-20 (sedikit lebih luas untuk penutup) -->
        <section id="contact" class="py-8 md:py-12 px-4 max-w-7xl mx-auto" data-aos="fade-up" data-aos-anchor-placement="center-bottom">
            <div class="max-w-3xl mx-auto bg-gradient-to-b from-slate-900/80 to-slate-950 border border-slate-800/80 rounded-[2rem] p-8 md:p-12 text-center shadow-2xl relative overflow-hidden transition-colors duration-300">
                
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-1 bg-gradient-to-r from-transparent via-indigo-500 to-transparent opacity-50"></div>
                
                <h2 class="text-3xl md:text-4xl font-bold text-white mb-3" data-aos="fade-right" data-aos-delay="100">
                    Mari Berkolaborasi
                </h2>
                
                <p class="text-slate-400 text-base md:text-lg leading-relaxed mb-8 max-w-xl mx-auto" data-aos="fade-right" data-aos-delay="200">
                    Saat ini saya terbuka untuk peluang pekerjaan baru. Baik Anda memiliki pertanyaan terkait sistem Web/Mobile, tawaran proyek, atau sekadar ingin menyapa, saya akan membalas secepatnya!
                </p>
                
                <div class="flex justify-center mb-10" data-aos="zoom-in" data-aos-delay="300">
                    <a href="mailto:suekabdy14@gmail.com" class="px-6 py-3 md:px-8 md:py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-all duration-300 flex items-center justify-center gap-2 shadow-lg shadow-indigo-500/20 hover:-translate-y-1 text-sm md:text-base">
                        <i class="fa-solid fa-paper-plane"></i> Kirim Pesan Email
                    </a>
                </div>

                <div class="pt-8 border-t border-slate-800/80">
                    <p class="text-sm text-slate-500 mb-5 font-medium uppercase tracking-wider">Atau temukan saya di</p>
                    
                    <div class="flex flex-wrap justify-center gap-3 md:gap-4 text-sm font-medium">
                        <a href="https://github.com/abdyuniors" target="_blank" aria-label="GitHub Profil" 
                           class="px-4 py-2 md:px-5 md:py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white rounded-xl transition-all duration-300 flex items-center gap-2 border border-slate-700 hover:-translate-y-1 hover:border-slate-500"
                           data-aos="zoom-in" data-aos-delay="400" data-aos-anchor="#contact">
                            <i class="fa-brands fa-github text-base"></i> GitHub
                        </a>
                        
                        <a href="https://linkedin.com/in/abdyuniors" target="_blank" aria-label="LinkedIn Profil" 
                           class="px-4 py-2 md:px-5 md:py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white rounded-xl transition-all duration-300 flex items-center gap-2 border border-slate-700 hover:-translate-y-1 hover:border-blue-500"
                           data-aos="zoom-in" data-aos-delay="500" data-aos-anchor="#contact">
                            <i class="fa-brands fa-linkedin text-base text-blue-400"></i> LinkedIn
                        </a>

                        <a href="https://instagram.com/abdyuniors" target="_blank" aria-label="Instagram Profil" 
                           class="px-4 py-2 md:px-5 md:py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white rounded-xl transition-all duration-300 flex items-center gap-2 border border-slate-700 hover:-translate-y-1 hover:border-pink-500"
                           data-aos="zoom-in" data-aos-delay="600" data-aos-anchor="#contact">
                            <i class="fa-brands fa-instagram text-base text-pink-500"></i> Instagram
                        </a>

                        <a href="https://facebook.com/abdysuek" target="_blank" aria-label="Facebook Profil" 
                           class="px-4 py-2 md:px-5 md:py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white rounded-xl transition-all duration-300 flex items-center gap-2 border border-slate-700 hover:-translate-y-1 hover:border-blue-500"
                           data-aos="zoom-in" data-aos-delay="700" data-aos-anchor="#contact">
                            <i class="fa-brands fa-facebook text-base text-blue-600"></i> Facebook
                        </a>
                    </div>
                </div>
            </div>
        </section>

    </main>
</Layout>

<script>
    // Import NPM Module
    import VanillaTilt from 'vanilla-tilt';

    document.addEventListener("DOMContentLoaded", function() {
        
        // ==========================================
        // 1. INISIALISASI EFEK 3D (VANILLA TILT)
        // ==========================================
        // Mengambil semua elemen html yang memiliki atribut data-tilt
        const tiltElements = document.querySelectorAll<HTMLElement>("[data-tilt]");
        
        if (tiltElements.length > 0) {
            // Inisialisasi library VanillaTilt
            VanillaTilt.init(Array.from(tiltElements));
        }

        // ==========================================
        // 2. INISIALISASI EFEK SPOTLIGHT (GLOW KURSOR)
        // ==========================================
        const spotlightCards = document.querySelectorAll<HTMLElement>(".spotlight-card");
        
        spotlightCards.forEach(card => {
            card.addEventListener("mousemove", function(e) {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left; // X relatif ke kartu
                const y = e.clientY - rect.top;  // Y relatif ke kartu
                
                // Meneruskan koordinat ke file global.css
                card.style.setProperty("--mouse-x", `${x}px`);
                card.style.setProperty("--mouse-y", `${y}px`);
            });
        });

        // ==========================================
        // 3. EFEK MENGETIK (TYPING EFFECT)
        // ==========================================
        const words = ["Mobile Developer", "Web Developer", "Full-Stack Developer"];
        let wordIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        let typeTimeout: number | ReturnType<typeof setTimeout>;
        
        const textElement = document.getElementById('typing-text');

        function doTyping() {
            if (!textElement) return;

            const currentWord = words[wordIndex];
            
            if (isDeleting) {
                textElement.textContent = currentWord.substring(0, charIndex - 1);
                charIndex--;
            } else {
                textElement.textContent = currentWord.substring(0, charIndex + 1);
                charIndex++;
            }

            let typeSpeed = isDeleting ? 50 : 100;

            if (!isDeleting && charIndex === currentWord.length) {
                typeSpeed = 2000; // Pause sebelum menghapus
                isDeleting = true;
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                wordIndex = (wordIndex + 1) % words.length;
                typeSpeed = 500; // Pause sebelum mengetik kata baru
            }

            typeTimeout = setTimeout(doTyping, typeSpeed);
        }

        if(textElement) {
            clearTimeout(typeTimeout as number);
            textElement.textContent = ""; 
            doTyping();
        }
    });
</script>