---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<Layout title="Portfolio | abdyuniors">
    <main class="pt-24 pb-12">
        
        <!-- Hero Section -->
        <section class="min-h-[70vh] flex items-center justify-center text-center px-4 animate-fade-in">
            <div class="max-w-3xl">
                <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-6">
                    Hai, Saya <span class="bg-gradient-to-r from-indigo-400 to-teal-400 bg-clip-text text-transparent">Abdy</span>
                </h1>
                
                <div class="text-xl md:text-2xl text-slate-400 font-medium h-8 mb-8">
                    Saya seorang <span id="typing-text" class="text-indigo-400 border-r-2 border-indigo-400 pr-1"></span>
                </div>
                
                <p class="text-slate-400 text-lg leading-relaxed mb-10 max-w-xl mx-auto">
                    Developer yang menjembatani ekosistem mobile native menggunakan <strong class="text-slate-200">Kotlin</strong> dan platform web modern dengan logika backend terstruktur berbasis <strong class="text-slate-200">Laravel</strong>.
                </p>
                
                <div class="flex gap-4 justify-center">
                    <a href="#projects" class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-xl shadow-lg shadow-indigo-500/20 transition-all duration-300 hover:-translate-y-1">Lihat Proyek</a>
                </div>
            </div>
        </section>

        <!-- Tech Stack Section (BARU) -->
        <section id="tech" class="py-16 px-4 max-w-4xl mx-auto animate-fade-in" style="animation-delay: 0.2s;">
            <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
                <span class="text-indigo-500">01.</span> Tech Stack & Alat
            </h2>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <!-- Laravel -->
                <div class="p-6 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-red-500/50 hover:bg-slate-900 hover:-translate-y-1 group">
                    <i class="fa-brands fa-laravel text-4xl text-slate-500 group-hover:text-red-500 transition-colors mb-3"></i>
                    <span class="text-sm font-medium text-slate-400 group-hover:text-white transition-colors">Laravel / PHP</span>
                </div>
                <!-- Kotlin -->
                <div class="p-6 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-purple-500/50 hover:bg-slate-900 hover:-translate-y-1 group">
                    <i class="fa-brands fa-android text-4xl text-slate-500 group-hover:text-purple-500 transition-colors mb-3"></i>
                    <span class="text-sm font-medium text-slate-400 group-hover:text-white transition-colors">Kotlin / Android</span>
                </div>
                <!-- Tailwind -->
                <div class="p-6 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-teal-500/50 hover:bg-slate-900 hover:-translate-y-1 group">
                    <svg class="w-10 h-10 text-slate-500 group-hover:text-teal-400 transition-colors mb-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12.001,4.8c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624 C13.666,10.618,15.027,12,18.001,12c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624 C16.337,6.182,14.976,4.8,12.001,4.8z M6.001,12c-3.2,0-5.2,1.6-6,4.8c1.2-1.6,2.6-2.2,4.2-1.8c0.913,0.228,1.565,0.89,2.288,1.624 c1.177,1.194,2.538,2.576,5.512,2.576c3.2,0,5.2-1.6,6-4.8c-1.2,1.6-2.6,2.2-4.2,1.8c-0.913-0.228-1.565-0.89-2.288-1.624 C10.337,13.382,8.976,12,6.001,12z"/></svg>
                    <span class="text-sm font-medium text-slate-400 group-hover:text-white transition-colors">Tailwind CSS</span>
                </div>
                <!-- Database -->
                <div class="p-6 bg-slate-900/40 border border-slate-800/80 rounded-2xl flex flex-col items-center justify-center transition-all duration-300 hover:border-blue-500/50 hover:bg-slate-900 hover:-translate-y-1 group">
                    <i class="fa-solid fa-database text-4xl text-slate-500 group-hover:text-blue-400 transition-colors mb-3"></i>
                    <span class="text-sm font-medium text-slate-400 group-hover:text-white transition-colors">MySQL</span>
                </div>
            </div>
        </section>

        <!-- Projects Section -->
        <section id="projects" class="py-16 px-4 max-w-4xl mx-auto animate-fade-in" style="animation-delay: 0.4s;">
            <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
                <span class="text-indigo-500">02.</span> Proyek Unggulan
            </h2>
            
            <div class="space-y-6">
                <!-- Komponen Kartu Proyek -->
                <ProjectCard 
                    title="Sistem Pendukung Keputusan (SPK) KNN"
                    type="Web Application"
                    typeColor="text-red-400 bg-red-500/10 border-red-500/10"
                    link="https://github.com/abdyuniors/spkknn"
                    description="Otomatisasi penentuan status kelayakan jalan kendaraan angkutan umum menggunakan algoritma klasifikasi K-Nearest Neighbor (KNN) untuk akurasi data keputusan."
                    techStacks={['Laravel', 'PHP', 'MySQL', 'Tailwind CSS']}
                />
                
                <ProjectCard 
                    title="Lapor TVRI NTT"
                    type="Mobile Application"
                    typeColor="text-emerald-400 bg-emerald-500/10 border-emerald-500/10"
                    link="https://github.com/abdyuniors/LaporTVRINTT"
                    description="Aplikasi pelaporan internal dan publik untuk stasiun penyiaran TVRI NTT yang dirancang native dengan berfokus pada siklus proses yang responsif."
                    techStacks={['Kotlin', 'Android SDK', 'Material Design']}
                />

                <ProjectCard 
                    title="QuiisinApp"
                    type="Mobile Application"
                    typeColor="text-emerald-400 bg-emerald-500/10 border-emerald-500/10"
                    link="https://github.com/abdyuniors/QuiisinApp"
                    description="Aplikasi interaktif yang dirancang khusus untuk optimalisasi performa penyimpanan data lokal dan manajemen state UI yang stabil pada perangkat Android."
                    techStacks={['Kotlin', 'Android Studio', 'Local Storage']}
                />
            </div>
        </section>

        <!-- Contact & Social Media Section -->
        <section id="contact" class="py-24 px-4 animate-fade-in" style="animation-delay: 0.6s;">
            <div class="max-w-3xl mx-auto bg-gradient-to-b from-slate-900/80 to-slate-950 border border-slate-800/80 rounded-[2rem] p-8 md:p-12 text-center shadow-2xl relative overflow-hidden">
                <!-- Dekorasi Background -->
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-1 bg-gradient-to-r from-transparent via-indigo-500 to-transparent opacity-50"></div>
                
                <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Mari Berkolaborasi</h2>
                <p class="text-slate-400 text-base md:text-lg leading-relaxed mb-8 max-w-xl mx-auto">
                    Saat ini saya terbuka untuk peluang pekerjaan baru. Baik Anda memiliki pertanyaan terkait sistem Web/Mobile, tawaran proyek, atau sekadar ingin menyapa, saya akan membalas secepatnya!
                </p>
                
                <!-- Tombol Aksi Utama (Email) -->
                <div class="flex justify-center mb-10">
                    <a href="mailto:emailanda@gmail.com" class="px-8 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-all duration-300 flex items-center justify-center gap-2 shadow-lg shadow-indigo-500/20 hover:-translate-y-1">
                        <i class="fa-solid fa-paper-plane"></i> Kirim Pesan Email
                    </a>
                </div>

                <!-- Pemisah & Social Media Buttons -->
                <div class="pt-8 border-t border-slate-800/80">
                    <p class="text-sm text-slate-500 mb-6 font-medium uppercase tracking-wider">Atau temukan saya di</p>
                    
                    <div class="flex flex-wrap justify-center gap-4">
                        <!-- GitHub -->
                        <a href="https://github.com/abdyuniors" target="_blank" aria-label="GitHub Profil" class="px-5 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white font-medium rounded-xl transition-all duration-300 flex items-center gap-2 border border-slate-700 hover:-translate-y-1 hover:border-slate-500">
                            <i class="fa-brands fa-github text-lg"></i> GitHub
                        </a>
                        
                        <!-- LinkedIn -->
                        <a href="https://linkedin.com/" target="_blank" aria-label="LinkedIn Profil" class="px-5 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white font-medium rounded-xl transition-all duration-300 flex items-center gap-2 border border-slate-700 hover:-translate-y-1 hover:border-blue-500">
                            <i class="fa-brands fa-linkedin text-lg text-blue-400"></i> LinkedIn
                        </a>

                        <!-- Instagram -->
                        <a href="https://instagram.com/" target="_blank" aria-label="Instagram Profil" class="px-5 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white font-medium rounded-xl transition-all duration-300 flex items-center gap-2 border border-slate-700 hover:-translate-y-1 hover:border-pink-500">
                            <i class="fa-brands fa-instagram text-lg text-pink-500"></i> Instagram
                        </a>

                        <a href="https://facebook.com/" target="_blank" aria-label="Facebook Profil" class="px-5 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white font-medium rounded-xl transition-all duration-300 flex items-center gap-2 border border-slate-700 hover:-translate-y-1 hover:border-blue-500">
                            <i class="fa-brands fa-facebook text-lg text-blue-600"></i> Facebook
                        </a>
                    </div>
                </div>
            </div>
        </section>

    </main>
</Layout>

<!-- Script Vanilla JS untuk Typing Effect -->
<script>
    const words = ["Mobile Developer (Kotlin)", "Web Developer (Laravel)", "Full-Stack Explorer"];
    let i = 0;
    let timer;

    function typingEffect() {
        let word = words[i].split("");
        var loopTyping = function() {
            if (word.length > 0) {
                const textElement = document.getElementById('typing-text');
                if(textElement) textElement.innerHTML += word.shift();
            } else {
                setTimeout(deletingEffect, 2000);
                return false;
            }
            timer = setTimeout(loopTyping, 100);
        };
        loopTyping();
    }

    function deletingEffect() {
        let word = words[i].split("");
        var loopDeleting = function() {
            if (word.length > 0) {
                word.pop();
                const textElement = document.getElementById('typing-text');
                if(textElement) textElement.innerHTML = word.join("");
            } else {
                if (words.length > (i + 1)) {
                    i++;
                } else {
                    i = 0;
                }
                setTimeout(typingEffect, 500);
                return false;
            }
            timer = setTimeout(loopDeleting, 50);
        };
        loopDeleting();
    }

    document.addEventListener("DOMContentLoaded", function() {
        typingEffect();
    });
</script>