---
// src/components/ProjectCard.astro
const { title, type, typeColor, link, description, techStacks } = Astro.props;
---

<div class="group relative bg-slate-900/40 border border-slate-800/80 rounded-2xl p-6 md:p-8 transition-all duration-300 hover:-translate-y-1 hover:border-slate-700 hover:bg-slate-900/70 shadow-xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-4">
        <div>
            <span class={`text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-md border ${typeColor}`}>
                {type}
            </span>
            <h3 class="text-xl font-bold text-white mt-3 group-hover:text-indigo-400 transition-colors">{title}</h3>
        </div>
        <a href={link} target="_blank" aria-label="Kunjungi profil GitHub saya" class="text-slate-400 hover:text-white text-xl transition-colors">
            <i class="fa-brands fa-github"></i>
        </a>
    </div>
    
    <p class="text-slate-400 text-sm md:text-base leading-relaxed mb-6">
        {description}
    </p>
    
    <div class="flex flex-wrap gap-2 text-xs font-mono text-slate-400">
        {techStacks.map((tech: string) => (
            <span class="px-2.5 py-1 bg-slate-950 rounded-md border border-slate-800">{tech}</span>
        ))}
    </div>
</div>